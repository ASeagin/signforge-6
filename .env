PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development
JWT_SECRET=change_this_to_any_long_random_string_abc123xyz

# STRIPE — get keys from https://dashboard.stripe.com/apikeys
# Money lands in your bank account (add bank in Stripe dashboard)
# Stripe takes 2.9% + $0.30 per charge. On $4.99 you keep ~$4.55
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME

# EMAIL — get key from https://resend.com (free: 3000 emails/month)
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@yourdomain.com
APP_NAME=SignForge
